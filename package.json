  "repository": {
    "type": "git",
    "url": "https://github.com/angelux/dynacontext.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "vite": "^6.3.5"
